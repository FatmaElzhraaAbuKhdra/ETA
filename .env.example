# ── Oracle Database ──────────────────────────────────────────────
DB_USER=CRM
DB_PASSWORD=CRM
DB_DSN=IP_ADDRESS:1521/ORCLPDB
ORACLE_MODE=thin
# ORACLE_CLIENT_PATH=C:\oracle\instantclient_21_3   # thick mode only

# ── Credentials Table ────────────────────────────────────────────
CREDENTIALS_TABLE=CUST
CREDENTIALS_FILTER=CUST_TYPE=0
COL_USERNAME=USERNM
COL_PASSWORD=PW
COL_CLIENT_NAME=CUST_NAME
COL_CLIENT_ID=CUSTID

# ── Browser ──────────────────────────────────────────────────────
HEADLESS=true
MAX_CONCURRENT=2
PAGE_TIMEOUT=90000

# ── API Security (اختياري — اتركه فارغاً للتطوير المحلي) ────────
# API_KEY=your-secret-key-here
# ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ── Password Encryption (اختياري) ───────────────────────────────
# لتوليد مفتاح جديد: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=your-fernet-key-here

# ── Misc ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=30
DOCS_DIR=documents
